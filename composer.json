{
    "name": "zpm-packages/cron-manager-filament",
    "description": "Filament plugin for managing system and database-synced cron jobs.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "ZPMPackages",
            "email": "developer@zpm-packages.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "filament/filament": "~5.0",
        "livewire/livewire": "^4.0",
        "zpm-packages/cron-manager-laravel": "^1.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0@dev",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "ZPMPackages\\FilamentCronManager\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ZPMPackages\\FilamentCronManager\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ZPMPackages\\FilamentCronManager\\FilamentCronManagerServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}